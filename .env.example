# ── Web app (apps/web) ────────────────────────────────────────────────
# Reown AppKit project id, create one at https://cloud.reown.com
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Sepolia RPC endpoint used by wagmi/viem (public default works, private is faster)
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Base URL of the Obscura API (apps/api) once deployed; empty disables API reads
NEXT_PUBLIC_API_URL=http://localhost:4000

# Base URL of the developer docs site (apps/docs); the nav Developers link
# and the /developers redirect point here
# Production (set on the apps/web Vercel project): https://obscura-doc.vercel.app
NEXT_PUBLIC_DOCS_URL=http://localhost:3001

# ── Docs site (apps/docs) ─────────────────────────────────────────────
# Base URL of the web app, used by the docs navbar "Open the app" link
# Production (set on the apps/docs Vercel project): https://obs-cura.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Indexer / API (apps/api) ──────────────────────────────────────────
PORT=4000
MONGODB_URI=
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Allowed CORS origin(s) for the API, comma-separated; "*" allows any
CORS_ORIGIN=*

# How often the indexer polls for new blocks, and the TVS snapshot job runs (ms)
INDEXER_POLL_INTERVAL_MS=20000
TVS_INTERVAL_MS=300000

# Max block range per eth_getLogs call. Free-tier RPCs are often capped hard
# (Alchemy's free plan allows only 10 blocks per call). Raise this if your
# provider allows a wider range.
INDEXER_CHUNK_SIZE=10

# Cold-start scan floor for the event-driven indexers. This only bounds how
# far back the *activity feed* sees; current pair coverage always comes
# from a direct registry state read (reconcilePairs), independent of log
# history. Leave REGISTRY_START_BLOCK empty to fall back to a bounded
# look-back (REGISTRY_LOOKBACK_BLOCKS) from the latest block, or set it to
# the registry's actual deployment block for full activity history on an
# archive-capable RPC (Alchemy Growth+, Infura, QuickNode, etc.).
REGISTRY_START_BLOCK=
REGISTRY_LOOKBACK_BLOCKS=5000
